# Postgres
POSTGRES_PASSWORD=silence

# Enable local MinIO containers (profile `minio`). Omit or leave empty when using Cloudflare R2.
COMPOSE_PROFILES=minio

# Object storage (MinIO defaults for local; override with Cloudflare R2 in production)
S3_ENDPOINT=http://minio:9000
# REQUIRED for browser uploads: must be reachable from the user's browser.
# Local MinIO: http://localhost:9000
# Dokploy + MinIO: https://minio.your-domain.com (or use Cloudflare R2 and set both endpoints to the R2 API URL)
S3_PUBLIC_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=silence-remover
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_FORCE_PATH_STYLE=true

# For Cloudflare R2 (production): unset COMPOSE_PROFILES (or leave empty) so MinIO is not started.
# S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_PUBLIC_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
# S3_REGION=auto
# S3_ACCESS_KEY=<r2_access_key>
# S3_SECRET_KEY=<r2_secret_key>
# S3_FORCE_PATH_STYLE=true
# COMPOSE_PROFILES=

# Object retention: worker deletes input/output objects after this many hours (default 1 day).
OBJECT_RETENTION_HOURS=24
CLEANUP_INTERVAL_SEC=900

# Presigned URL lifetime (seconds) — not object retention.
# UPLOAD_URL_TTL_SEC=3600
# DOWNLOAD_URL_TTL_SEC=3600

# Rate limits
RATE_LIMIT_JOBS_PER_DAY=10
RATE_LIMIT_MAX_CONCURRENT=2
MAX_UPLOAD_BYTES=209715200

# Web -> API (inside Docker network)
API_INTERNAL_URL=http://api:8080
CORS_ORIGINS=*

# Public site URL (Open Graph / WhatsApp link previews need an absolute origin)
NEXT_PUBLIC_SITE_URL=https://silence-remover.puhulab.com

# Umami analytics (public; baked into the Next.js image at build time)
# Set NEXT_PUBLIC_UMAMI_DISABLED=1 to turn the tracker off (e.g. local).
NEXT_PUBLIC_UMAMI_URL=https://umami.puhulab.com
NEXT_PUBLIC_UMAMI_WEBSITE_ID=c7dec9db-2640-478b-8a56-ae99633c31df
# NEXT_PUBLIC_UMAMI_DISABLED=1

# Bugsink error tracking (Sentry-compatible). Leave unset locally to disable.
# Frontend needs NEXT_PUBLIC_SENTRY_DSN at **image build** time (not only runtime).
# Production:
# SENTRY_DSN=https://bf63b1c07dd743f8a55d2678057e145f@bugsink.puhulab.com/1
# NEXT_PUBLIC_SENTRY_DSN=https://bf63b1c07dd743f8a55d2678057e145f@bugsink.puhulab.com/1
# SENTRY_ENVIRONMENT=production
# Smoke test UI: https://your-site/?bugsink_test=1
# NEXT_PUBLIC_SENTRY_DISABLED=1
# SENTRY_DISABLED=1
